{
  "name": "crystal",
  "private": true,
  "version": "0.8.0",
  "description": "Crystal is a desktop home base for long-running AI agents. Powered by OpenClaw, vLLM, NVIDIA Parakeet STT, and NVIDIA Magpie TTS, with Telegram as a remote channel.",
  "keywords": [
    "ai-agents",
    "desktop-app",
    "tauri",
    "openclaw",
    "vllm",
    "nvidia",
    "parakeet",
    "magpie",
    "llm",
    "mempalace",
    "voice-assistant",
    "local-ai"
  ],
  "license": "MIT",
  "author": "Jarrod",
  "homepage": "https://juiceclaw.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/jvpflum/Crystal"
  },
  "bugs": {
    "url": "https://github.com/jvpflum/Crystal/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "openclaw",
      "sharp",
      "protobufjs",
      "koffi",
      "@matrix-org/matrix-sdk-crypto-nodejs"
    ]
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.0"
  }
}
